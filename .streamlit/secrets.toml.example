# Copie para Secrets no painel Streamlit Cloud (Settings → Secrets)
# https://share.streamlit.io/

LLM_PROVIDER = "gemini"
GEMINI_API_KEY = "sua_chave_aqui"
GEMINI_MODEL = "gemini-2.0-flash"

# URL pública da app (opcional — usado no link do formulário dos júris)
# APP_URL = "https://avaliapap.streamlit.app"

PAP_ADMIN_USER = "admin"
PAP_ADMIN_PASSWORD = "altere_esta_password"
PAP_ADMIN_NOME = "Administrador"
