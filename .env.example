# Motor de IA: ollama (local, gratuito) | gemini | auto
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Opcional - quota gratuita pode esgotar (erro 429)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Autenticação (primeiro utilizador criado automaticamente se a BD estiver vazia)
PAP_ADMIN_USER=admin
PAP_ADMIN_PASSWORD=altere_esta_password
PAP_ADMIN_NOME=Administrador
